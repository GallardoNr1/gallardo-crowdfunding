---
export interface Props {
  year?: number;
}

const currentYear = new Date().getFullYear();
const { year = currentYear } = Astro.props;
---

<footer class='footer'>
  <div class='footer-container'>
    <div class='footer-brand'>
      <a href='/' class='footer-logo-link' title='Ir a la página principal'>
        <svg class='footer-logo-svg' viewBox='0 0 238 64' fill='none' xmlns='http://www.w3.org/2000/svg'>
          <defs>
            <linearGradient id='gc-footer-grad' x1='0' y1='0' x2='64' y2='64' gradientUnits='userSpaceOnUse'>
              <stop stop-color='#ff6b35'/>
              <stop offset='1' stop-color='#c62828'/>
            </linearGradient>
          </defs>
          <rect width='64' height='64' rx='15' fill='url(#gc-footer-grad)'/>
          <rect x='29' y='0' width='6' height='64' fill='white' opacity='0.10' rx='3'/>
          <rect x='0' y='29' width='64' height='6' fill='white' opacity='0.10' rx='3'/>
          <ellipse cx='25' cy='12' rx='7' ry='3.5' fill='white' opacity='0.22' transform='rotate(-20 25 12)'/>
          <ellipse cx='39' cy='12' rx='7' ry='3.5' fill='white' opacity='0.22' transform='rotate(20 39 12)'/>
          <circle cx='32' cy='12' r='3' fill='white' opacity='0.30'/>
          <text x='32' y='47' font-family="'Arial Black',sans-serif" font-size='26' font-weight='900' fill='white' text-anchor='middle' letter-spacing='-0.5'>GC</text>
          <line x1='80' y1='10' x2='80' y2='54' stroke='rgba(255,255,255,0.18)' stroke-width='1.5' stroke-linecap='round'/>
          <text x='90' y='30' font-family="'Helvetica Neue',Arial,sans-serif" font-size='17' font-weight='700' fill='#f0f4ff' letter-spacing='0.3'>Gallardo</text>
          <text x='90' y='49' font-family="'Helvetica Neue',Arial,sans-serif" font-size='10' font-weight='700' fill='#ff6b35' letter-spacing='2.5'>CROWDFUNDING</text>
        </svg>
      </a>
      <p class='brand-tagline'>Proyectos familiares llenos de corazón 💛</p>
    </div>

    <!-- <div class='footer-links'>
      <a
        href='/'
        class='footer-link'
        >Inicio</a
      >
      <a
        href='/about'
        class='footer-link'
        >Sobre nosotros</a
      >
      <a
        href='/contact'
        class='footer-link'
        >Contacto</a
      >
    </div> -->

    <div class='footer-copy'>
      <p>© {year} • Plataforma familiar creada con cariño</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-header-bg);
    color: #e5e7eb;
    padding: 40px 20px;
    text-align: center;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    margin-top: 40px;
  }

  .footer-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .footer-brand {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .footer-logo-link {
    display: inline-block;
    transition: var(--transition-normal);
  }

  .footer-logo-link:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .footer-logo-svg {
    width: 200px;
    height: auto;
    display: block;
  }

  .brand-tagline {
    font-size: 0.9rem;
    opacity: 0.65;
  }

  .footer-links {
    margin: 25px 0;
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .footer-link {
    color: #e5e7eb;
    text-decoration: none;
    font-size: 0.95rem;
    transition: var(--transition-normal);
  }

  .footer-link:hover {
    opacity: 0.6;
  }

  .footer-copy {
    margin-top: 20px;
    font-size: 0.8rem;
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .footer-links {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>
