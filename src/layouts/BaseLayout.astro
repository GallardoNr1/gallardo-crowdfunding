---
import '../styles/tokens.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ContributionModal from '@/components/ContributionModal.astro';
import { getPaymentMethods, getProjectBySlug } from '@/lib/supabase';

export interface Props {
  title: string;
  description?: string;
  subtitle?: string;
}

const {
  title,
  description = 'Plataforma familiar de crowdfundings Gallardo',
  subtitle,
} = Astro.props;

const { slug } = Astro.params;
const projectConfig = await getProjectBySlug(slug || '');
const customPaymentMethods = await getPaymentMethods();
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta
      name='viewport'
      content='width=device-width, initial-scale=1.0'
    />
    <meta
      name='description'
      content={description}
    />
    <title>{title}</title>
    <link rel='icon' href='/favicon.svg' type='image/svg+xml' />
    <link rel='shortcut icon' href='/favicon.svg' />

    <link
      rel='preconnect'
      href='https://fonts.googleapis.com'
    />
    <link
      rel='preconnect'
      href='https://fonts.gstatic.com'
      crossorigin
    />
    <link
      href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap'
      rel='stylesheet'
    />
    <link
      rel='stylesheet'
      href='/styles/global.css'
    />
  </head>
  <body>
    <Header
      title={title}
      subtitle={subtitle}
    />
    <main class='main-content'>
      <slot />
    </main>
    <slot name='footer' />
    <div id='gc-toast-container'></div>
    <ContributionModal
      paymentMethods={customPaymentMethods}
      currency='€'
      modalTitle='Apoya el proyecto familiar'
      modalIcon='🧡'
      modalSubtitle='Ayuda a la familia a crear recuerdos inolvidables'
      summaryTitle='Resumen de tu aporte'
      formTitle='Tus datos'
      paymentTitle='Selecciona método'
      successTitle='¡Gracias por tu apoyo!'
      successMessage='Hemos registrado tu contribución correctamente.'
      cancelButtonText='Cerrar'
      confirmButtonText='Confirmar y Registrar'
      bizumConcept={projectConfig?.bizum_concept || ''}
      bizumNumber={projectConfig?.bizum_phone || ''}
      totalLabel='Total a contribuir:'
      emojiOptions={projectConfig?.emoji_options &&
      projectConfig.emoji_options.length > 0
        ? projectConfig.emoji_options
        : [
            { value: '🙂', label: 'Amigo de la familia' },
            { value: '💛', label: 'Colaborador' },
          ]}
      projectId={projectConfig?.id && projectConfig.id}
    />
  </body>
</html>

<style is:global>
  #gc-toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 10002;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .gc-toast {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    border-radius: 12px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.13);
    font-family: 'Poppins', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    max-width: 320px;
    pointer-events: all;
    animation: toastIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .gc-toast--out { animation: toastOut 0.3s ease-in forwards; }

  @keyframes toastIn  {
    from { transform: translateX(110%); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
  }
  @keyframes toastOut {
    from { transform: translateX(0);    opacity: 1; }
    to   { transform: translateX(110%); opacity: 0; }
  }

  .gc-toast-icon  { font-size: 1.1rem; flex-shrink: 0; }
  .gc-toast-msg   { flex: 1; line-height: 1.4; }
  .gc-toast-close {
    background: none; border: none; cursor: pointer;
    font-size: 1.2rem; opacity: 0.5; padding: 0 2px;
    color: inherit; line-height: 1; flex-shrink: 0;
  }
  .gc-toast-close:hover { opacity: 1; }
</style>

<script is:inline>
  window.showToast = function (message, type, duration) {
    type = type || 'info';
    duration = duration || 4500;
    var styles = {
      success: { bg: '#f0fdf4', border: '#bbf7d0', text: '#166534', icon: '✅' },
      error:   { bg: '#fef2f2', border: '#fecaca', text: '#991b1b', icon: '❌' },
      warning: { bg: '#fffbeb', border: '#fde68a', text: '#92400e', icon: '⚠️' },
      info:    { bg: '#eff6ff', border: '#bfdbfe', text: '#1e40af', icon: 'ℹ️' },
    };
    var s = styles[type] || styles.info;
    var container = document.getElementById('gc-toast-container');
    if (!container) return;

    var toast = document.createElement('div');
    toast.className = 'gc-toast';
    toast.style.cssText = 'background:' + s.bg + ';border:1.5px solid ' + s.border + ';color:' + s.text;
    toast.innerHTML =
      '<span class="gc-toast-icon">' + s.icon + '</span>' +
      '<span class="gc-toast-msg">' + message + '</span>' +
      '<button class="gc-toast-close" onclick="this.parentElement.remove()" aria-label="Cerrar">×</button>';

    container.appendChild(toast);

    setTimeout(function () {
      toast.classList.add('gc-toast--out');
      setTimeout(function () { if (toast.parentElement) toast.remove(); }, 320);
    }, duration);
  };
</script>
