---
export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Gallardo Crowdfunding',
  subtitle = 'Elige un proyecto y únete a hacerlo realidad',
} = Astro.props;
---

<dic class='header-bg'>
  <div class='header'>
    <div class='left'>
      <a class='home-link' href='/' title='Ir a la página principal'>
        <svg class='logo-svg' viewBox='0 0 64 64' fill='none' xmlns='http://www.w3.org/2000/svg'>
          <defs>
            <linearGradient id='gc-header-grad' x1='0' y1='0' x2='64' y2='64' gradientUnits='userSpaceOnUse'>
              <stop stop-color='#ff6b35'/>
              <stop offset='1' stop-color='#c62828'/>
            </linearGradient>
          </defs>
          <rect width='64' height='64' rx='15' fill='url(#gc-header-grad)'/>
          <rect x='29' y='0' width='6' height='64' fill='white' opacity='0.10' rx='3'/>
          <rect x='0' y='29' width='64' height='6' fill='white' opacity='0.10' rx='3'/>
          <ellipse cx='25' cy='12' rx='7' ry='3.5' fill='white' opacity='0.22' transform='rotate(-20 25 12)'/>
          <ellipse cx='39' cy='12' rx='7' ry='3.5' fill='white' opacity='0.22' transform='rotate(20 39 12)'/>
          <circle cx='32' cy='12' r='3' fill='white' opacity='0.30'/>
          <text x='32' y='47' font-family="'Arial Black',sans-serif" font-size='26' font-weight='900' fill='white' text-anchor='middle' letter-spacing='-0.5'>GC</text>
        </svg>
      </a>
    </div>

    <div class='center'>
      <h1 class='title'>{title}</h1>
      <p class='subtitle'>{subtitle}</p>
    </div>
  </div>
</dic>

<style>
  .header-bg {
    background: var(--color-header-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .header {
    display: flex;
    align-items: center;
    padding: 35px 20px;
    margin-bottom: 40px;
    gap: 20px;
    width: 100%;
    max-width: 1200px;
  }

  .left {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .center {
    flex: 1;
    text-align: center;
  }

  .logo-svg {
    width: 68px;
    height: 68px;
    display: block;
    transition: var(--transition-normal);
    filter: drop-shadow(0 4px 12px rgba(255, 107, 53, 0.35));
  }

  .home-link:hover .logo-svg {
    transform: scale(1.07) rotate(-3deg);
    filter: drop-shadow(0 6px 18px rgba(255, 107, 53, 0.55));
  }

  .title {
    font-family: var(--font-body);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-header-text);
    margin: 0;
  }

  .subtitle {
    font-size: var(--text-md);
    color: var(--color-header-subtitle);
    margin-top: 6px;
  }

  @media (max-width: 768px) {
    .header {
      flex-direction: column;
      padding: 25px 20px;
    }

    .center {
      text-align: center;
    }

    .logo-svg {
      width: 56px;
      height: 56px;
    }
  }
</style>
