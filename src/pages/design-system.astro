---
export const prerender = false;
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Design System — Gallardo Crowdfunding</title>
    <link
      href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Fredoka+One&family=Inter:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <link rel='stylesheet' href='/styles/global.css' />
    <link rel='stylesheet' href='/styles/tokens.css' />
  </head>

  <body class='ds-body'>
    <nav class='ds-nav'>
      <span class='ds-nav-brand'>🎨 Design System</span>
      <div class='ds-nav-links'>
        <a href='#colors'>Colores</a>
        <a href='#typography'>Tipografía</a>
        <a href='#spacing'>Espaciado</a>
        <a href='#shadows'>Sombras</a>
        <a href='#components'>Componentes</a>
        <a href='#animations'>Animaciones</a>
      </div>
    </nav>

    <div class='ds-container'>

      <!-- Hero -->
      <header class='ds-hero'>
        <h1>Gallardo Crowdfunding</h1>
        <p>Design System — fuente de verdad visual del proyecto</p>
        <div class='ds-meta'>
          <span>Fuentes: Poppins · Fredoka One · Inter</span>
          <span>Tokens en <code>src/styles/tokens.css</code></span>
        </div>
      </header>

      <!-- ── COLORES ────────────────────────────────────────────── -->
      <section id='colors' class='ds-section'>
        <h2 class='ds-section-title'>Colores</h2>

        <h3 class='ds-group-title'>Marca</h3>
        <div class='ds-swatches'>
          <div class='ds-swatch' style='background:#d32f2f'>
            <span class='ds-swatch-name'>brand-primary</span>
            <span class='ds-swatch-val'>#d32f2f</span>
          </div>
          <div class='ds-swatch' style='background:#ff6b35'>
            <span class='ds-swatch-name'>brand-orange</span>
            <span class='ds-swatch-val'>#ff6b35</span>
          </div>
          <div class='ds-swatch' style='background:#f7931e'>
            <span class='ds-swatch-name'>brand-orange-alt</span>
            <span class='ds-swatch-val'>#f7931e</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#ffcc02'>
            <span class='ds-swatch-name'>brand-yellow</span>
            <span class='ds-swatch-val'>#ffcc02</span>
          </div>
          <div class='ds-swatch' style='background:#4caf50'>
            <span class='ds-swatch-name'>brand-green</span>
            <span class='ds-swatch-val'>#4caf50</span>
          </div>
          <div class='ds-swatch' style='background:#2e7d32'>
            <span class='ds-swatch-name'>brand-green-dark</span>
            <span class='ds-swatch-val'>#2e7d32</span>
          </div>
          <div class='ds-swatch' style='background:#8bc34a'>
            <span class='ds-swatch-name'>brand-green-light</span>
            <span class='ds-swatch-val'>#8bc34a</span>
          </div>
          <div class='ds-swatch' style='background:#667eea'>
            <span class='ds-swatch-name'>brand-purple</span>
            <span class='ds-swatch-val'>#667eea</span>
          </div>
          <div class='ds-swatch' style='background:#764ba2'>
            <span class='ds-swatch-name'>brand-purple-dark</span>
            <span class='ds-swatch-val'>#764ba2</span>
          </div>
        </div>

        <h3 class='ds-group-title'>UI / Superficie</h3>
        <div class='ds-swatches'>
          <div class='ds-swatch' style='background:#1f2937'>
            <span class='ds-swatch-name'>header-bg</span>
            <span class='ds-swatch-val'>#1f2937</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#ffffff; border:1px solid #e2e8f0'>
            <span class='ds-swatch-name' style='color:#333'>surface</span>
            <span class='ds-swatch-val' style='color:#333'>#ffffff</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#f8f9fa; border:1px solid #e2e8f0'>
            <span class='ds-swatch-name' style='color:#333'>surface-muted</span>
            <span class='ds-swatch-val' style='color:#333'>#f8f9fa</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#333333'>
            <span class='ds-swatch-name'>text-primary</span>
            <span class='ds-swatch-val'>#333333</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#666666'>
            <span class='ds-swatch-name'>text-muted</span>
            <span class='ds-swatch-val'>#666666</span>
          </div>
        </div>

        <h3 class='ds-group-title'>Estados</h3>
        <div class='ds-swatches'>
          <div class='ds-swatch' style='background:#4caf50'>
            <span class='ds-swatch-name'>status-active</span>
            <span class='ds-swatch-val'>#4caf50</span>
          </div>
          <div class='ds-swatch' style='background:#2196f3'>
            <span class='ds-swatch-name'>status-completed</span>
            <span class='ds-swatch-val'>#2196f3</span>
          </div>
          <div class='ds-swatch' style='background:#ff9800'>
            <span class='ds-swatch-name'>status-paused</span>
            <span class='ds-swatch-val'>#ff9800</span>
          </div>
          <div class='ds-swatch' style='background:#f44336'>
            <span class='ds-swatch-name'>status-cancelled</span>
            <span class='ds-swatch-val'>#f44336</span>
          </div>
        </div>

        <h3 class='ds-group-title'>Admin (backoffice)</h3>
        <div class='ds-swatches'>
          <div class='ds-swatch' style='background:#6366f1'>
            <span class='ds-swatch-name'>admin-primary</span>
            <span class='ds-swatch-val'>#6366f1</span>
          </div>
          <div class='ds-swatch' style='background:#4f46e5'>
            <span class='ds-swatch-name'>admin-primary-dk</span>
            <span class='ds-swatch-val'>#4f46e5</span>
          </div>
          <div class='ds-swatch' style='background:#1e1b4b'>
            <span class='ds-swatch-name'>admin-sidebar</span>
            <span class='ds-swatch-val'>#1e1b4b</span>
          </div>
          <div class='ds-swatch ds-swatch--dark' style='background:#f1f5f9; border:1px solid #e2e8f0'>
            <span class='ds-swatch-name' style='color:#333'>admin-bg</span>
            <span class='ds-swatch-val' style='color:#333'>#f1f5f9</span>
          </div>
        </div>

        <h3 class='ds-group-title'>Gradientes de fondo</h3>
        <div class='ds-gradients'>
          <div class='ds-gradient' style='background:linear-gradient(135deg,#bcbec0,#e6e7e8,#a7a8aa)'>
            <span>body-bg (activo)</span>
          </div>
          <div class='ds-gradient' style='background:linear-gradient(135deg,#667eea,#764ba2)'>
            <span>body-bg-alt</span>
          </div>
          <div class='ds-gradient' style='background:linear-gradient(145deg,#fff3e0,#ffcc02)'>
            <span>section-progress</span>
          </div>
          <div class='ds-gradient' style='background:linear-gradient(145deg,#e8f5e8,#c8e6c8)'>
            <span>section-levels</span>
          </div>
          <div class='ds-gradient' style='background:linear-gradient(145deg,#ff6b35,#f7931e)'>
            <span>cta-button</span>
          </div>
          <div class='ds-gradient' style='background:linear-gradient(90deg,#4caf50,#8bc34a,#4caf50)'>
            <span>progress-bar</span>
          </div>
        </div>
      </section>

      <!-- ── TIPOGRAFÍA ─────────────────────────────────────────── -->
      <section id='typography' class='ds-section'>
        <h2 class='ds-section-title'>Tipografía</h2>

        <div class='ds-type-families'>
          <div class='ds-type-family'>
            <div class='ds-font-label'>Poppins — <code>--font-body</code></div>
            <div style='font-family:Poppins,sans-serif'>
              <div style='font-weight:300'>300 Light — Texto de apoyo</div>
              <div style='font-weight:400'>400 Regular — Texto base del cuerpo</div>
              <div style='font-weight:600'>600 Semibold — Etiquetas y badges</div>
              <div style='font-weight:700'>700 Bold — Títulos secundarios</div>
            </div>
          </div>
          <div class='ds-type-family'>
            <div class='ds-font-label'>Fredoka One — <code>--font-display</code></div>
            <div style='font-family:"Fredoka One",cursive; font-size:2rem; color:#d32f2f'>
              Títulos de sección
            </div>
            <div style='font-family:"Fredoka One",cursive; font-size:1.5rem; color:#2e7d32'>
              🏰 Niveles de Contribución
            </div>
          </div>
          <div class='ds-type-family'>
            <div class='ds-font-label'>Inter — <code>--font-admin</code></div>
            <div style='font-family:Inter,sans-serif'>
              <div style='font-weight:400'>400 — Texto general del backoffice</div>
              <div style='font-weight:500'>500 — Labels de formulario</div>
              <div style='font-weight:600'>600 — Títulos de sección admin</div>
              <div style='font-weight:700'>700 — Headings del admin</div>
            </div>
          </div>
        </div>

        <h3 class='ds-group-title'>Escala de tamaños</h3>
        <div class='ds-type-scale'>
          <div class='ds-type-row'><span class='ds-type-token'>--text-xs (12px)</span><span style='font-size:0.75rem'>Texto muy pequeño, timestamps</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-sm (14px)</span><span style='font-size:0.875rem'>Labels, badges, meta</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-base (16px)</span><span style='font-size:1rem'>Cuerpo de texto base</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-md (18px)</span><span style='font-size:1.1rem'>Texto destacado, subtítulos</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-lg (19px)</span><span style='font-size:1.2rem'>Subtítulo del header</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-xl (22px)</span><span style='font-size:1.4rem'>Importes, porcentajes</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-2xl (29px)</span><span style='font-size:1.8rem; font-weight:700'>Títulos de sección</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-3xl (32px)</span><span style='font-size:2rem; font-weight:700'>Título del header</span></div>
          <div class='ds-type-row'><span class='ds-type-token'>--text-4xl (40px)</span><span style='font-size:2.5rem; font-family:"Fredoka One",cursive; color:#d32f2f'>Título de producto</span></div>
        </div>
      </section>

      <!-- ── ESPACIADO ──────────────────────────────────────────── -->
      <section id='spacing' class='ds-section'>
        <h2 class='ds-section-title'>Espaciado & Bordes</h2>

        <h3 class='ds-group-title'>Escala de espacio</h3>
        <div class='ds-spacing-scale'>
          {[
            ['--space-1', '4px'],
            ['--space-2', '8px'],
            ['--space-3', '12px'],
            ['--space-4', '16px'],
            ['--space-5', '20px'],
            ['--space-6', '24px'],
            ['--space-7', '28px'],
            ['--space-8', '30px — gap entre secciones'],
            ['--space-10','40px — padding tarjetas'],
            ['--space-12','48px'],
          ].map(([token, val]) => (
            <div class='ds-space-row'>
              <code class='ds-space-token'>{token}</code>
              <div class='ds-space-bar' style={`width:${parseInt(val)}px`} />
              <span class='ds-space-val'>{val}</span>
            </div>
          ))}
        </div>

        <h3 class='ds-group-title'>Border radius</h3>
        <div class='ds-radius-grid'>
          {[
            ['--radius-sm',  '8px'],
            ['--radius-md',  '12px'],
            ['--radius-lg',  '15px'],
            ['--radius-xl',  '20px'],
            ['--radius-2xl', '25px'],
            ['--radius-full','9999px'],
          ].map(([token, val]) => (
            <div class='ds-radius-item'>
              <div class='ds-radius-box' style={`border-radius:${val}`} />
              <code>{token}</code>
              <span>{val}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── SOMBRAS ─────────────────────────────────────────────── -->
      <section id='shadows' class='ds-section'>
        <h2 class='ds-section-title'>Sombras</h2>
        <div class='ds-shadows-grid'>
          {[
            ['shadow-sm',  '0 1px 4px rgba(0,0,0,.06)',     'Tarjetas admin'],
            ['shadow-md',  '0 5px 15px rgba(0,0,0,.10)',    'Level cards'],
            ['shadow-lg',  '0 10px 30px rgba(0,0,0,.12)',   'Imágenes'],
            ['shadow-xl',  '0 20px 40px rgba(0,0,0,.10)',   'Main card'],
            ['shadow-orange','0 8px 25px rgba(255,107,53,.30)','CTA button'],
            ['shadow-green', '0 4px 15px rgba(76,175,80,.30)', 'Confirm button'],
            ['shadow-yellow','0 10px 30px rgba(255,204,2,.20)', 'Progress section'],
          ].map(([name, val, use]) => (
            <div class='ds-shadow-item' style={`box-shadow:${val}`}>
              <code class='ds-shadow-name'>--{name}</code>
              <span class='ds-shadow-use'>{use}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── COMPONENTES ─────────────────────────────────────────── -->
      <section id='components' class='ds-section'>
        <h2 class='ds-section-title'>Componentes</h2>

        <!-- Botones -->
        <h3 class='ds-group-title'>Botones</h3>
        <div class='ds-component-row'>
          <button class='btn-cta'>✨ Contribuir 25€ ✨</button>
          <button class='btn-cta' disabled>Selecciona un nivel primero</button>
          <button class='btn-confirm'>🚀 Confirmar y Registrar ✨</button>
          <button class='btn-confirm' disabled>Procesando...</button>
          <button class='btn-cancel'>Cancelar</button>
          <a class='btn-admin-primary'>➕ Nuevo proyecto</a>
          <a class='btn-admin-secondary'>✏️ Editar</a>
          <a class='btn-admin-ghost'>👁 Ver</a>
        </div>

        <!-- Badges de estado -->
        <h3 class='ds-group-title'>Badges de estado</h3>
        <div class='ds-component-row'>
          <span class='badge badge--active'>Activo</span>
          <span class='badge badge--completed'>Completado</span>
          <span class='badge badge--paused'>Pausado</span>
          <span class='badge badge--cancelled'>Cancelado</span>
        </div>

        <!-- Tarjeta de nivel -->
        <h3 class='ds-group-title'>Level card</h3>
        <div class='ds-levels-demo'>
          {[
            { emoji:'⭐', name:'Colaborador', amount:15, color:'#667eea', desc:'Para empezar' },
            { emoji:'🛡️', name:'Guardián',   amount:30, color:'#ff9800', desc:'Para los valientes' },
            { emoji:'👑', name:'Paladín',    amount:55, color:'#d32f2f', desc:'Para los más generosos' },
          ].map(l => (
            <div class='demo-level-card' style={`--level-color:${l.color}`}>
              <div class='demo-level-emoji'>{l.emoji}</div>
              <div class='demo-level-name'>{l.name}</div>
              <div class='demo-level-amount'>{l.amount} €</div>
              <div class='demo-level-desc'>{l.desc}</div>
            </div>
          ))}
        </div>

        <!-- Barra de progreso -->
        <h3 class='ds-group-title'>Barra de progreso</h3>
        <div class='demo-progress-section'>
          <div class='demo-progress-container'>
            <div class='demo-progress-bar' style='width: 68%'>
              <div class='demo-progress-shine'></div>
            </div>
          </div>
          <div class='demo-progress-info'>
            <span>Recaudado: <strong>110.00 €</strong></span>
            <span class='demo-pct'>68%</span>
            <span>Objetivo: <strong>159.00 €</strong></span>
          </div>
        </div>

        <!-- Header -->
        <h3 class='ds-group-title'>Header</h3>
        <div class='demo-header'>
          <a class='demo-logo'><span class='demo-logo-inner'>GC</span></a>
          <div class='demo-header-text'>
            <div class='demo-title'>Gallardo Crowdfunding</div>
            <div class='demo-subtitle'>Elige un proyecto y únete a hacerlo realidad</div>
          </div>
        </div>

        <!-- Alert / Banner -->
        <h3 class='ds-group-title'>Alertas</h3>
        <div class='ds-component-col'>
          <div class='alert alert--error'>⚠️ Email o contraseña incorrectos.</div>
          <div class='alert alert--success'>✅ Proyecto actualizado correctamente.</div>
          <div class='alert alert--warning'>⚠️ Modo demostración — problema de conexión.</div>
        </div>

        <!-- Input / Form field -->
        <h3 class='ds-group-title'>Campos de formulario</h3>
        <div class='ds-form-demo'>
          <div class='demo-field'>
            <label>Nombre</label>
            <input type='text' placeholder='¿Cómo te llamaremos?' />
          </div>
          <div class='demo-field'>
            <label>Email</label>
            <input type='email' placeholder='tu@email.com' />
          </div>
          <div class='demo-field'>
            <label>Mensaje (opcional)</label>
            <textarea rows='2' placeholder='Deja un mensaje de apoyo...'></textarea>
          </div>
        </div>
      </section>

      <!-- ── ANIMACIONES ─────────────────────────────────────────── -->
      <section id='animations' class='ds-section'>
        <h2 class='ds-section-title'>Animaciones</h2>
        <div class='ds-anim-grid'>
          <div class='ds-anim-item'>
            <div class='anim-demo anim-bounce'>⭐</div>
            <code>bounce</code>
            <span>Emojis de selección, iconos CTA</span>
          </div>
          <div class='ds-anim-item'>
            <div class='anim-demo anim-float'>🎁</div>
            <code>float</code>
            <span>Elementos flotantes de fondo</span>
          </div>
          <div class='ds-anim-item'>
            <div class='anim-demo anim-fadein'>✨</div>
            <code>fadeIn</code>
            <span>Aparición de elementos</span>
          </div>
          <div class='ds-anim-item'>
            <div class='anim-demo anim-fadeinup'>🏰</div>
            <code>fadeInUp</code>
            <span>Secciones al hacer scroll</span>
          </div>
          <div class='ds-anim-item'>
            <div class='anim-demo'>
              <div style='height:12px;background:linear-gradient(90deg,#4caf50,#8bc34a);border-radius:6px;width:80%;animation:gradientShift 3s ease-in-out infinite'></div>
            </div>
            <code>gradientShift</code>
            <span>Barra de progreso</span>
          </div>
          <div class='ds-anim-item'>
            <div class='anim-demo' style='position:relative;overflow:hidden;background:#e0e0e0;border-radius:8px'>
              <div style='position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.6),transparent);animation:shimmer 1.5s infinite'></div>
            </div>
            <code>shimmer</code>
            <span>Efecto brillo sobre barra</span>
          </div>
        </div>

        <h3 class='ds-group-title'>Transiciones</h3>
        <div class='ds-component-row'>
          <div class='ds-transition-demo ds-t-fast'>fast (0.15s) — hover admin</div>
          <div class='ds-transition-demo ds-t-normal'>normal (0.3s) — hover cards</div>
          <div class='ds-transition-demo ds-t-spring'>spring cubic-bezier — level cards</div>
        </div>
      </section>

    </div><!-- /ds-container -->

    <style>
      /* ── Shell ── */
      .ds-body {
        font-family: 'Inter', sans-serif;
        background: #f8fafc;
        color: #1e293b;
        min-height: 100vh;
      }

      .ds-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #1e1b4b;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        height: 52px;
        gap: 16px;
      }

      .ds-nav-brand {
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        white-space: nowrap;
      }

      .ds-nav-links {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
      }

      .ds-nav-links a {
        color: rgba(255,255,255,.7);
        text-decoration: none;
        font-size: 0.8rem;
        padding: 4px 10px;
        border-radius: 4px;
        transition: all .15s;
      }

      .ds-nav-links a:hover {
        background: rgba(255,255,255,.1);
        color: #fff;
      }

      .ds-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 24px 80px;
      }

      /* ── Hero ── */
      .ds-hero {
        text-align: center;
        padding: 48px 0 40px;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 48px;
      }

      .ds-hero h1 {
        font-family: 'Fredoka One', cursive;
        font-size: 3rem;
        color: #d32f2f;
        margin-bottom: 8px;
      }

      .ds-hero p { color: #64748b; font-size: 1.05rem; margin-bottom: 16px; }

      .ds-meta {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: #94a3b8;
      }

      .ds-meta code {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        color: #6366f1;
      }

      /* ── Sections ── */
      .ds-section { margin-bottom: 64px; }

      .ds-section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1e293b;
        padding-bottom: 12px;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 28px;
      }

      .ds-group-title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #94a3b8;
        margin: 28px 0 12px;
      }

      /* ── Swatches ── */
      .ds-swatches {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .ds-swatch {
        width: 100px;
        height: 80px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        padding: 8px;
        gap: 2px;
      }

      .ds-swatch-name, .ds-swatch-val {
        font-size: 0.65rem;
        color: rgba(255,255,255,.9);
        text-align: center;
        line-height: 1.2;
      }

      .ds-swatch-name { font-weight: 600; }

      /* ── Gradients ── */
      .ds-gradients { display: flex; flex-wrap: wrap; gap: 12px; }

      .ds-gradient {
        width: 160px;
        height: 60px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .ds-gradient span {
        font-size: 0.7rem;
        color: rgba(255,255,255,.9);
        font-weight: 600;
        text-shadow: 0 1px 2px rgba(0,0,0,.3);
        text-align: center;
        padding: 0 8px;
      }

      /* ── Typography ── */
      .ds-type-families {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 8px;
      }

      .ds-type-family {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 20px;
      }

      .ds-font-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #94a3b8;
        margin-bottom: 14px;
      }

      .ds-font-label code { color: #6366f1; background: #f1f5f9; padding: 1px 5px; border-radius: 3px; }

      .ds-type-scale { display: flex; flex-direction: column; gap: 10px; }

      .ds-type-row {
        display: flex;
        align-items: baseline;
        gap: 16px;
        padding: 6px 0;
        border-bottom: 1px solid #f1f5f9;
      }

      .ds-type-token { font-size: 0.75rem; color: #6366f1; font-family: monospace; width: 180px; flex-shrink: 0; }

      /* ── Spacing ── */
      .ds-spacing-scale { display: flex; flex-direction: column; gap: 8px; }

      .ds-space-row {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .ds-space-token { font-size: 0.78rem; color: #6366f1; font-family: monospace; width: 120px; flex-shrink: 0; }

      .ds-space-bar {
        height: 16px;
        background: #6366f1;
        border-radius: 3px;
        min-width: 4px;
        transition: width .3s;
      }

      .ds-space-val { font-size: 0.78rem; color: #64748b; }

      /* ── Radii ── */
      .ds-radius-grid { display: flex; flex-wrap: wrap; gap: 16px; }

      .ds-radius-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        color: #64748b;
      }

      .ds-radius-item code { color: #6366f1; }

      .ds-radius-box {
        width: 64px;
        height: 40px;
        background: #6366f1;
      }

      /* ── Shadows ── */
      .ds-shadows-grid { display: flex; flex-wrap: wrap; gap: 20px; }

      .ds-shadow-item {
        background: #fff;
        border-radius: 10px;
        padding: 20px;
        width: 180px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .ds-shadow-name { font-size: 0.75rem; color: #6366f1; font-family: monospace; }
      .ds-shadow-use  { font-size: 0.75rem; color: #94a3b8; }

      /* ── Buttons ── */
      .ds-component-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
      }

      .ds-component-col { display: flex; flex-direction: column; gap: 10px; }

      .btn-cta {
        background: linear-gradient(145deg, #ff6b35, #f7931e);
        color: white;
        border: none;
        padding: 14px 36px;
        border-radius: 25px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 8px 25px rgba(255,107,53,.30);
        font-family: 'Poppins', sans-serif;
        transition: all .3s cubic-bezier(.4,0,.2,1);
      }

      .btn-cta:not(:disabled):hover {
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 15px 35px rgba(255,107,53,.4);
      }

      .btn-cta:disabled { background: linear-gradient(145deg,#bbb,#999); cursor:not-allowed; box-shadow:none; }

      .btn-confirm {
        background: linear-gradient(145deg,#4caf50,#45a049);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 25px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(76,175,80,.3);
        font-family: 'Poppins', sans-serif;
        transition: all .3s;
      }

      .btn-confirm:disabled { background: #ccc; cursor: not-allowed; box-shadow: none; }

      .btn-cancel {
        padding: 12px 24px;
        border: 2px solid #e0e0e0;
        background: white;
        color: #666;
        border-radius: 25px;
        cursor: pointer;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
      }

      .btn-admin-primary {
        background: #6366f1; color: #fff; padding: 9px 18px; border-radius: 8px;
        font-size: 0.9rem; font-weight: 600; text-decoration: none; cursor: pointer;
        font-family: Inter, sans-serif;
      }

      .btn-admin-secondary {
        background: #f1f5f9; color: #374151; padding: 7px 14px; border-radius: 8px;
        font-size: 0.875rem; font-weight: 500; text-decoration: none; cursor: pointer;
        font-family: Inter, sans-serif;
      }

      .btn-admin-ghost {
        color: #64748b; padding: 7px 14px; border-radius: 8px;
        font-size: 0.875rem; text-decoration: none; cursor: pointer;
        font-family: Inter, sans-serif;
      }

      /* ── Badges ── */
      .badge {
        font-size: 0.78rem; font-weight: 600; padding: 4px 12px; border-radius: 20px;
      }

      .badge--active    { color: #16a34a; background: #16a34a18; }
      .badge--completed { color: #2563eb; background: #2563eb18; }
      .badge--paused    { color: #d97706; background: #d9770618; }
      .badge--cancelled { color: #dc2626; background: #dc262618; }

      /* ── Level cards demo ── */
      .ds-levels-demo { display: flex; gap: 16px; flex-wrap: wrap; }

      .demo-level-card {
        background: white;
        border-radius: 15px;
        padding: 25px 20px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,.1);
        border: 3px solid transparent;
        cursor: pointer;
        transition: all .3s cubic-bezier(.4,0,.2,1);
        min-width: 160px;
      }

      .demo-level-card:hover {
        transform: translateY(-8px) scale(1.02);
        border-color: var(--level-color);
        box-shadow: 0 15px 30px rgba(0,0,0,.15);
      }

      .demo-level-emoji { font-size: 3rem; margin-bottom: 10px; }
      .demo-level-name  { font-weight: 700; color: #333; margin-bottom: 6px; }
      .demo-level-amount { font-size: 1.6rem; font-weight: 800; color: var(--level-color); margin-bottom: 8px; }
      .demo-level-desc  { font-size: 0.85rem; color: #666; }

      /* ── Progress demo ── */
      .demo-progress-section {
        background: linear-gradient(145deg, #fff3e0, #ffcc02);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(255,204,2,.2);
      }

      .demo-progress-container {
        background: #fff;
        border-radius: 25px;
        padding: 8px;
        margin-bottom: 16px;
        box-shadow: inset 0 4px 12px rgba(0,0,0,.1);
        overflow: hidden;
      }

      .demo-progress-bar {
        height: 32px;
        background: linear-gradient(90deg, #4caf50, #8bc34a, #4caf50);
        background-size: 200% 100%;
        border-radius: 20px;
        position: relative;
        overflow: hidden;
        animation: gradientShift 3s ease-in-out infinite;
      }

      .demo-progress-shine {
        position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
        background: linear-gradient(90deg,transparent,rgba(255,255,255,.4),transparent);
        animation: shine 2s infinite 1s;
      }

      @keyframes gradientShift { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
      @keyframes shine { 0%{left:-100%} 100%{left:100%} }

      .demo-progress-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
        color: #555;
      }

      .demo-pct {
        font-size: 1.4rem;
        font-weight: 700;
        color: #2e7d32;
        background: white;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #4caf50;
      }

      /* ── Header demo ── */
      .demo-header {
        background: #1f2937;
        border-radius: 12px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .demo-logo {
        width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0;
        background: radial-gradient(circle at 30% 30%,#4b5563,#1f2937);
        border: 3px solid #6b7280;
        display: flex; align-items: center; justify-content: center; cursor: pointer;
      }

      .demo-logo-inner { font-size: 1.3rem; font-weight: 800; color: #f9fafb; }

      .demo-title    { font-family: 'Poppins',sans-serif; font-size: 1.5rem; font-weight: 700; color: #f3f4f6; }
      .demo-subtitle { font-size: 0.9rem; color: #d1d5db; }

      /* ── Alerts ── */
      .alert {
        padding: 13px 18px; border-radius: 8px; font-size: 0.9rem;
        display: flex; align-items: center; gap: 8px;
      }

      .alert--error   { background:#fef2f2; border:1px solid #fecaca; color:#991b1b; }
      .alert--success { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; font-weight:500; }
      .alert--warning { background:#fff3cd; border:1px solid #ffeeba; color:#856404; }

      /* ── Form demo ── */
      .ds-form-demo { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 560px; }

      .demo-field { display: flex; flex-direction: column; gap: 5px; }

      .demo-field label { font-size: 0.845rem; font-weight: 500; color: #374151; }

      .demo-field input, .demo-field textarea {
        padding: 9px 13px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.9rem;
        font-family: inherit;
        color: #0f172a;
        transition: border-color .15s;
      }

      .demo-field input:focus, .demo-field textarea:focus {
        outline: none; border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.08);
      }

      .demo-field textarea { resize: vertical; }

      /* ── Animations ── */
      .ds-anim-grid { display: flex; flex-wrap: wrap; gap: 20px; }

      .ds-anim-item {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        min-width: 140px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
      }

      .ds-anim-item code { font-size: 0.75rem; color: #6366f1; }
      .ds-anim-item span { font-size: 0.72rem; color: #94a3b8; }

      .anim-demo { font-size: 2rem; width: 60px; height: 60px; display:flex; align-items:center; justify-content:center; }

      @keyframes bounce { 0%,20%,50%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-10px)} 60%{transform:translateY(-5px)} }
      @keyframes float  { 0%,100%{transform:translateY(0) rotate(0)} 50%{transform:translateY(-14px) rotate(180deg)} }
      @keyframes fadein { from{opacity:0} to{opacity:1} }
      @keyframes fadeinup { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

      .anim-bounce  { animation: bounce 2s infinite; }
      .anim-float   { animation: float 3s ease-in-out infinite; }
      .anim-fadein  { animation: fadein 2s ease infinite alternate; }
      .anim-fadeinup { animation: fadeinup 2s ease infinite alternate; }

      /* ── Transitions demo ── */
      .ds-transition-demo {
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 0.82rem;
        color: #374151;
        cursor: pointer;
      }

      .ds-t-fast:hover   { background: #6366f1; color: #fff; transition: all .15s ease; }
      .ds-t-normal:hover { background: #6366f1; color: #fff; transition: all .3s ease; }
      .ds-t-spring:hover { background: #6366f1; color: #fff; transition: all .3s cubic-bezier(.4,0,.2,1); transform: translateY(-4px); }

      @media (max-width: 640px) {
        .ds-nav-links { display: none; }
        .ds-form-demo { grid-template-columns: 1fr; }
      }
    </style>
  </body>
</html>
