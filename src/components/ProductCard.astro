---
import CompletedBage from './UI/CompletedBage.astro';

export interface Props {
  title: string;
  description: string;
  price: number;
  imageUrl: string;
  imageAlt: string;
  href?: string;
  completed?: boolean;
  icon?: string;
}

const { title, description, price, imageUrl, imageAlt, href, completed, icon } =
  Astro.props;
---

<div
  class='main-card'
  style={icon ? `--card-icon: "${icon}"` : undefined}
>
  {completed && <CompletedBage size='lg' />}

  <a
    class='product-title'
    href={href || '#'}
    target='_blank'
    title='Ver set'
  >
    <img
      src={`${imageUrl}`}
      alt={imageAlt}
      class='lego-image'
    />
  </a>

  <h2 class='product-title'>{title}</h2>
  <p class='product-description'>{description}</p>

  <div class='price'>
    <span>💰</span>
    <span>{price.toFixed(2)} €</span>
  </div>
</div>

<style>
  .main-card {
    background: linear-gradient(145deg, #ffffffcc, #f0f0f0);
    border-radius: var(--radius-2xl);
    padding: var(--space-10);
    box-shadow: var(--shadow-card);
    margin-bottom: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .main-card::before {
    content: var(--card-icon);
    position: absolute;
    top: -20px;
    right: -20px;
    font-size: 120px;
    opacity: 0.1;
    transform: rotate(15deg);
  }

  .lego-image {
    width: 100%;
    max-width: 500px;
    height: 300px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin: 0 auto 30px;
    display: block;
    box-shadow: var(--shadow-lg);
    transition: var(--transition-normal);
  }

  .lego-image:hover {
    transform: scale(1.05);
  }

  .product-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-brand-primary);
    margin-bottom: 15px;
    text-align: center;
  }

  .product-description {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 20px;
    text-align: center;
  }

  .price {
    font-size: 2rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-brand-green-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 30px;
  }

  @media (max-width: 768px) {
    .main-card {
      padding: 20px;
    }

    .product-title {
      font-size: 1.8rem;
    }

    .price {
      font-size: 1.5rem;
    }

    .completed-badge {
      font-size: 0.8rem;
      padding: 6px 12px;
    }
  }
</style>
